    {
      "name": "buckets",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"buckets\" (\"sync_state\" TEXT NOT NULL DEFAULT 'synced', \"deleted_local\" INTEGER NOT NULL DEFAULT 0 CHECK (\"deleted_local\" IN (0, 1)), \"updated_at_local\" INTEGER NULL, \"server_updated_at\" INTEGER NULL, \"id\" TEXT NOT NULL, \"name\" TEXT NOT NULL DEFAULT '', \"owner_id\" TEXT NOT NULL, \"join_code\" TEXT NOT NULL DEFAULT '', \"monthly_budget\" REAL NOT NULL DEFAULT 0.0, \"month_start_date\" TEXT NOT NULL, \"remaining_main_bucket\" REAL NOT NULL DEFAULT 0.0, \"currency\" TEXT NOT NULL DEFAULT 'INR', \"created_at\" INTEGER NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "weekly_bucket_rows",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"weekly_bucket_rows\" (\"sync_state\" TEXT NOT NULL DEFAULT 'synced', \"deleted_local\" INTEGER NOT NULL DEFAULT 0 CHECK (\"deleted_local\" IN (0, 1)), \"updated_at_local\" INTEGER NULL, \"server_updated_at\" INTEGER NULL, \"id\" TEXT NOT NULL, \"bucket_id\" TEXT NOT NULL, \"week_index\" INTEGER NOT NULL DEFAULT 0, \"start_date\" TEXT NOT NULL, \"end_date\" TEXT NOT NULL, \"effective_start_date\" TEXT NULL, \"kind\" TEXT NOT NULL DEFAULT 'active', \"allocated_amount\" REAL NOT NULL DEFAULT 0.0, \"spent_amount\" REAL NOT NULL DEFAULT 0.0, \"remaining_amount\" REAL NOT NULL DEFAULT 0.0, \"status\" TEXT NOT NULL DEFAULT 'active', PRIMARY KEY (\"id\"));"
        }
      ]
    },
